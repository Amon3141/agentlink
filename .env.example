NEXT_PUBLIC_SITE_URL=http://localhost:3000

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key
# Google sign-in: Supabase → Authentication → Providers → Google (enable + paste OAuth client ID/secret).
# Google Cloud Console → your OAuth client → Authorized redirect URIs MUST include Supabase’s callback only:
#   https://<your-project-ref>.supabase.co/auth/v1/callback
# (Do NOT put http://localhost:3000 here — that causes Error 400 redirect_uri_mismatch.)
# Supabase → Authentication → URL Configuration → Redirect URLs: add {NEXT_PUBLIC_SITE_URL}/auth/callback
# Server-only. Required for OAuth token persistence in the private schema.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Hackathon demo seed: npm run seed:hackathon (uses service role; creates demo auth users + data).
# HACKATHON_OWNER_USER_ID=
# HACKATHON_OWNER_USERNAME=
# HACKATHON_PARTNER_USER_ID=
# HACKATHON_PARTNER_EMAIL=kizawaamon@gmail.com

CLOD_ENDPOINT=https://api.clod.io/v1
CLOD_API_KEY=your-clod-api-key
CLOD_MODEL=DeepSeek V3

# Optional providers. When absent, provider cards show clear not-configured states.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3000/api/resources/github/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Backwards-compatible fallback used when GOOGLE_CALENDAR_REDIRECT_URI is absent.
GOOGLE_REDIRECT_URI=http://localhost:3000/api/resources/google-calendar/callback
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/api/resources/google-calendar/callback
GMAIL_REDIRECT_URI=http://localhost:3000/api/resources/gmail/callback

SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:3000/api/resources/slack/callback
